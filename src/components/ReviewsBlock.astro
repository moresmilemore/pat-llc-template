---
import ReviewTile from './ReviewTile.astro';

interface Review {
  text: string;
  rating: 1 | 2 | 3 | 4 | 5;
  author: string;
  date: string;
  platform: 'Google' | 'Yelp' | 'Facebook' | 'BBB' | 'Other';
  platformUrl?: string;
}

interface Props {
  reviews: Review[];        // exactly 3 chosen from research/reputation-harvest.md
  heading?: string;
  caption?: string;
  reviewSourceUrl?: string;  // Google Business Profile URL or similar — for "see all" link
  reviewCount?: number;
  averageRating?: number;
}

const {
  reviews,
  heading = 'What customers say',
  caption,
  reviewSourceUrl,
  reviewCount,
  averageRating,
} = Astro.props;
---

<section class="reviews" aria-labelledby="reviews-heading">
  {caption && <p class="reviews__caption">{caption}</p>}
  <header class="reviews__header">
    <h2 id="reviews-heading">{heading}</h2>
    {reviewCount && averageRating && (
      <p class="reviews__summary">
        <strong>{averageRating}/5</strong> from <strong>{reviewCount}</strong> verified reviews
      </p>
    )}
  </header>
  <div class="reviews__grid" role="list">
    {reviews.map((r) => (
      <div role="listitem">
        <ReviewTile {...r} />
      </div>
    ))}
  </div>
  {reviewSourceUrl && (
    <p class="reviews__more">
      <a href={reviewSourceUrl} rel="noopener noreferrer">Read all reviews →</a>
    </p>
  )}
</section>

<style>
  .reviews {
    padding: var(--space-16) var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
    background: var(--surface-warm);
    border-radius: var(--radius-lg);
  }
  .reviews__caption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 var(--space-2);
  }
  .reviews__header { display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-8); }
  .reviews__header h2 {
    font-size: clamp(28px, 4vw, 40px);
    margin: 0;
    text-wrap: balance;
  }
  .reviews__summary { color: var(--ink-secondary); margin: 0; font-size: 16px; }
  .reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 768px) {
    .reviews__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  }
  .reviews__more {
    margin-top: var(--space-8);
    text-align: center;
  }
  .reviews__more a { color: var(--accent-deep); text-decoration: none; font-weight: 500; }
  .reviews__more a:hover { text-decoration: underline; }
</style>
