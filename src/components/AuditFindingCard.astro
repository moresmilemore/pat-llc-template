---
// Single audit finding card. Verified-vs-illustrative integrity is binding —
// only mark VERIFIED what was actually observed on the live site fetch.
// (See KICKOFF_PROMPT anti-pattern #4 + BASE-AGENT.md §2 evidence rules.)

export type AuditSeverity = 'CRITICAL' | 'MODERATE' | 'MINOR';
export type AuditSource = 'VERIFIED' | 'ILLUSTRATIVE';

export interface AuditFinding {
  id: string;
  severity: AuditSeverity;
  source: AuditSource;
  title: string;
  detail: string;
  evidence?: string;
}

interface Props extends AuditFinding {}

const { id, severity, source, title, detail, evidence } = Astro.props;
---

<article class="finding" data-severity={severity.toLowerCase()}>
  <header class="finding__header">
    <span class:list={['badge', `badge--${severity.toLowerCase()}`]}>{severity}</span>
    <span class:list={['tag', `tag--${source.toLowerCase()}`]}>{source}</span>
    <span class="finding__id">{id}</span>
  </header>
  <h3 class="finding__title">{title}</h3>
  <p class="finding__detail">{detail}</p>
  {evidence && (
    <p class="finding__evidence">Evidence: <code>{evidence}</code></p>
  )}
</article>

<style>
  .finding {
    padding: var(--space-6);
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-left-width: 4px;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .finding[data-severity="critical"] { border-left-color: var(--error); }
  .finding[data-severity="moderate"] { border-left-color: #9C5F0E; }
  .finding[data-severity="minor"] { border-left-color: var(--ink-mute); }

  .finding__header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--surface);
  }
  .badge--critical { background: var(--error); }
  .badge--moderate { background: #9C5F0E; }
  .badge--minor { background: var(--ink-mute); }

  .tag {
    display: inline-block;
    padding: 4px 8px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-secondary);
    text-transform: uppercase;
  }
  .tag--verified { color: var(--success); border-color: var(--success); }
  .tag--illustrative { color: var(--ink-mute); }

  .finding__id {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-mute);
    margin-left: auto;
  }
  .finding__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .finding__detail {
    color: var(--ink-secondary);
    margin: 0;
    font-size: 15px;
    line-height: 1.55;
  }
  .finding__evidence {
    font-size: 13px;
    color: var(--ink-mute);
    margin: 0;
  }
  .finding__evidence code {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface-warm);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--ink-secondary);
  }
</style>
