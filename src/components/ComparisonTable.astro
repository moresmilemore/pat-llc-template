---
export interface ComparisonRow {
  dimension: string;
  current: string;
  industryStandard: string;
  proposed: string;
}

interface Props {
  rows: ComparisonRow[];
  heading?: string;
}

const { rows, heading = 'Current site vs. industry vs. proposed build' } = Astro.props;
---

<section class="comparison">
  <h2 class="comparison__heading">{heading}</h2>
  <div class="comparison__scroll" role="region" aria-label={heading} tabindex="0">
    <table>
      <thead>
        <tr>
          <th scope="col">Dimension</th>
          <th scope="col">Current</th>
          <th scope="col">Industry standard</th>
          <th scope="col">Pat LLC build</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <th scope="row">{r.dimension}</th>
            <td class="comparison__current">{r.current}</td>
            <td>{r.industryStandard}</td>
            <td class="comparison__proposed">{r.proposed}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .comparison {
    padding: var(--space-12) var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
  }
  .comparison__heading {
    font-size: clamp(24px, 3vw, 32px);
    margin: 0 0 var(--space-6);
    text-wrap: balance;
  }
  .comparison__scroll {
    overflow-x: auto;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
  }
  .comparison__scroll:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    min-width: 720px;
  }
  th, td {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    vertical-align: top;
  }
  thead th {
    background: var(--surface-warm);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    font-weight: 500;
    border-bottom: 1px solid var(--border-subtle);
  }
  tbody th {
    font-weight: 500;
    color: var(--ink-primary);
  }
  tbody tr {
    border-bottom: 1px solid var(--border-subtle);
  }
  tbody tr:last-child { border-bottom: none; }
  .comparison__current { color: var(--ink-secondary); }
  .comparison__proposed { color: var(--accent-deep); font-weight: 500; }
</style>
