---
interface Step {
  number: number;
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
  heading?: string;
  caption?: string;
}

const { steps, heading = 'How it works', caption } = Astro.props;
---

<section class="process" aria-labelledby="process-heading">
  {caption && <p class="process__caption">{caption}</p>}
  <h2 id="process-heading">{heading}</h2>
  <ol class="process__list">
    {steps.map((step) => (
      <li class="process__step">
        <span class="process__num" aria-hidden="true">{String(step.number).padStart(2, '0')}</span>
        <div class="process__body">
          <h3 class="process__title">{step.title}</h3>
          <p class="process__desc">{step.description}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .process {
    padding: var(--space-16) var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
  }
  .process__caption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 var(--space-2);
  }
  .process h2 {
    font-size: clamp(28px, 4vw, 40px);
    margin: 0 0 var(--space-8);
  }
  .process__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .process__list { grid-template-columns: repeat(4, 1fr); gap: var(--space-4); }
  }
  .process__step {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .process__step { flex-direction: column; gap: var(--space-3); }
  }
  .process__num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--accent-deep);
    letter-spacing: 0.08em;
    padding: 6px 10px;
    background: var(--surface-warm);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }
  .process__body { display: flex; flex-direction: column; gap: var(--space-2); }
  .process__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .process__desc {
    color: var(--ink-secondary);
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
  }
</style>
