---
// Per-service detail page. Generates one static page per entry in src/data/services.ts.
// Composition + body live in ServiceDetail; this file is just the route + getStaticPaths.

import SiteLayout from '../../layouts/SiteLayout.astro';
import ServiceDetail from '../../components/ServiceDetail.astro';
import { client } from '../../data/client';
import { services, type Service } from '../../data/services';

export async function getStaticPaths() {
  return services.map((s) => ({
    params: { slug: s.slug },
    props: { service: s },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;

const related: Service[] = service.related
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s): s is Service => Boolean(s))
  .slice(0, 3);
---

<SiteLayout
  title={`${service.name} — ${client.name}`}
  description={service.shortDescription}
>
  <ServiceDetail service={service} related={related} />
</SiteLayout>
