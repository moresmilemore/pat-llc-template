---
// Homepage. Composes Pat LLC production components with research-derived content.
// Phase 4 fine-tunes per the chosen direction (composition, copy, image selection).
// Components used: Hero, ServiceGrid, ReviewsBlock, ProcessSteps, AreaPills,
// TrustStrip, ContactForm. All ship JSON-LD + a11y + reduced-motion + 44px tap.

import SiteLayout from '../layouts/SiteLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ReviewsBlock from '../components/ReviewsBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AreaPills from '../components/AreaPills.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ContactForm from '../components/ContactForm.astro';
import { client } from '../data/client';
import { services } from '../data/services';

// Phase 4 fills these arrays from research/. Template ships with [CLIENT_TBD]
// markers so an unfilled engagement loudly fails the self-assessment battery
// rather than shipping placeholder content silently.

const trustSignals = [
  { label: 'Licensed', value: client.licenseNumber, icon: 'shield-check' },
  { label: 'Insured', value: client.insurance, icon: 'umbrella' },
  // Phase 4: append BBB / years-in-business / Google rating from research
];

const processSteps = [
  { number: 1, title: 'Call or text', description: 'Reach the owner, not a call center.' },
  { number: 2, title: 'On-site quote', description: 'Free, with a written estimate before any work.' },
  { number: 3, title: 'Scheduled job', description: 'Show-up window narrowed to the half-day.' },
  { number: 4, title: 'Done right', description: 'Workmanship guarantee on every job.' },
  // Phase 4: replace with real process from research/current-content-inventory.md if richer
];

const towns = [
  // Phase 4: pull from PROJECT_BRIEF.md service area + competitive teardown
  '[CLIENT_TBD — town 1]',
  '[CLIENT_TBD — town 2]',
  '[CLIENT_TBD — town 3]',
];

const reviewsForHomepage = [
  // Phase 4: paste exactly 3 verbatim reviews from research/reputation-harvest.md
  // Verbatim only — never paraphrased. See knowledge/conversion.md.
  // Removing this comment block before launch is part of QA Mode 2.
];
---

<SiteLayout
  title={`${client.name} — ${client.serviceArea}`}
  description={`${client.industry} services in ${client.serviceArea}. ${client.name}.`}
>
  <Hero
    variant="split"
    caption={client.industry?.toUpperCase()}
    headline={`${client.name}`}
    lede="[CLIENT_TBD — Phase 4: replace with one-sentence claim from research/current-site-strengths.md preserve list]"
    ctas={[
      { label: `Call ${client.phone}`, href: `tel:${client.phoneTel}`, variant: 'primary' },
      { label: 'See the audit →', href: '/audit', variant: 'ghost' },
    ]}
  />

  <TrustStrip signals={trustSignals} variant="full" />

  <ServiceGrid
    services={services}
    heading="Services"
    caption="WHAT WE DO"
  />

  <ProcessSteps steps={processSteps} heading="How we work" caption="PROCESS" />

  {reviewsForHomepage.length === 3 && (
    <ReviewsBlock
      reviews={reviewsForHomepage as any}
      heading="What customers say"
      caption="REVIEWS"
      reviewSourceUrl={client.reviewSourceUrl}
      reviewCount={client.reviewCount}
      averageRating={client.averageRating}
    />
  )}

  <AreaPills areas={towns} serviceArea={client.serviceArea} heading="Service area" />

  <ContactForm
    heading="Tell us about the job"
    caption="GET IN TOUCH"
    successMessage={`Thanks — ${client.name} will be in touch shortly.`}
  />
</SiteLayout>

<style>
  .hero {
    padding: var(--space-16) var(--space-6);
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }
  .hero__caption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 var(--space-4);
  }
  h1 {
    font-size: clamp(36px, 6vw, 64px);
    margin-bottom: var(--space-4);
  }
  .hero__lede {
    font-size: 18px;
    color: var(--ink-secondary);
    max-width: 640px;
    margin: 0 auto var(--space-8);
  }
  .hero__cta-row {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    padding: 12px 20px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-weight: 500;
    min-height: 44px;
  }
  .cta--primary { background: var(--primary); color: var(--surface); }
  .cta--primary:hover { background: var(--primary-deep); color: var(--surface); }
  .cta--ghost { background: transparent; color: var(--ink-primary); border: 1px solid var(--border-subtle); }
  .cta--ghost:hover { background: var(--surface-warm); }

  .phase4-checklist {
    padding: var(--space-12) var(--space-6);
    max-width: 720px;
    margin: 0 auto;
  }
  .phase4-checklist h2 { font-size: 24px; margin-bottom: var(--space-4); }
  .phase4-checklist ul { padding-left: var(--space-6); color: var(--ink-secondary); }
  .phase4-checklist li { margin-bottom: var(--space-2); }
  code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--surface-warm);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
