# Pat LLC template — environment variables
#
# Copy to .env (gitignored) and fill per-client. Vercel → Settings → Environment Variables
# for production; rules of thumb:
#   - Anything labeled SECRET goes in Vercel (never in client-side bundles)
#   - PUBLIC_ prefix means it's safe to expose to the browser
#
# All env access in code uses `astro:env/server` (typed) per knowledge/astro.md.

# Resend — transactional email (contact form)
# Sign up: https://resend.com → API Keys
RESEND_API_KEY=

# Email "from" address — must be on a verified domain in Resend
RESEND_FROM_EMAIL=

# Email "to" address — usually the client's contact inbox
RESEND_TO_EMAIL=

# Cloudflare Turnstile — spam protection on the contact form
# Sign up: https://www.cloudflare.com/products/turnstile/
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Vercel — auto-injected on deploy; here for reference
# VERCEL_URL=
# VERCEL_ENV=

# Optional — analytics
# PUBLIC_PLAUSIBLE_DOMAIN=
